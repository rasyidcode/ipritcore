generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Transaction {
  id        Int             @id @default(autoincrement())
  name      String
  amount    Int
  type      TransactionType
  date      DateTime        @db.Date
  createdAt DateTime?       @default(now())
  updatedAt DateTime?       @updatedAt
  userId    Int?
  user      User?           @relation(fields: [userId], references: [id])
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String        @default("")
  image        String?
  createdAt    DateTime?     @default(now())
  updatedAt    DateTime?     @updatedAt
  transactions Transaction[]
  groceryPlans GroceryPlan[]
}

model GroceryPlan {
  id        Int               @id @default(autoincrement())
  monthYear String
  budget    Int
  createdAt DateTime?         @default(now())
  updatedAt DateTime?         @updatedAt
  userId    Int?
  user      User?             @relation(fields: [userId], references: [id])
  groceries GroceryPlanItem[]
}

model GroceryPlanItem {
  id            Int          @id @default(autoincrement())
  name          String
  amount        Int
  price         Int
  createdAt     DateTime?    @default(now())
  updatedAt     DateTime?    @updatedAt
  groceryPlanId Int?
  groceryPlan   GroceryPlan? @relation(fields: [groceryPlanId], references: [id])
}

enum TransactionType {
  EXPENSE
  INCOME
}
